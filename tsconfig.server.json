{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "./dist/server",
    "rootDir": "./server",
    "lib": ["ES2020"]
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules", "dist", "client"]
}
