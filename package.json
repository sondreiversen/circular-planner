{
  "name": "circular-planner",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "esbuild planner=client/src/index.ts auth=client/src/auth.ts dashboard=client/src/dashboard.ts --bundle --outdir=public/js --entry-names=[name]-bundle --minify --target=es2020",
    "build:server": "tsc -p tsconfig.server.json && mkdir -p dist/server/migrations && cp server/migrations/*.sql dist/server/migrations/",
    "dev": "concurrently \"nodemon --watch server -e ts --exec 'ts-node --project tsconfig.server.json server/index.ts'\" \"esbuild planner=client/src/index.ts auth=client/src/auth.ts dashboard=client/src/dashboard.ts --bundle --outdir=public/js --entry-names=[name]-bundle --sourcemap=inline --target=es2020 --watch\"",
    "start": "node dist/server/index.js",
    "start:go": "go run .",
    "build:go": "npm run build:client && go build -o planner .",
    "migrate": "ts-node server/migrations/migrate.ts",
    "create-admin": "node dist/server/scripts/create-admin.js",
    "test": "jest"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/d3-color": "^3.1.3",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-selection": "^3.0.10",
    "@types/d3-shape": "^3.1.6",
    "@types/d3-transition": "^3.0.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.25.12",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "d3-color": "^3.1.0",
    "d3-drag": "^3.0.0",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-timer": "^3.0.1",
    "d3-transition": "^3.0.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "roots": [
      "<rootDir>/client/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^d3-scale$": "<rootDir>/client/src/__tests__/__mocks__/d3-scale.ts"
    }
  }
}
