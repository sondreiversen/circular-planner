{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "lib": ["ES2017", "DOM"]
  },
  "include": ["client/src/**/*"],
  "exclude": ["node_modules", "dist", "server"]
}
